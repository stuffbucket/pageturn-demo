# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Large media kept on CDN, not in git
public/videos/

# Harness capture outputs
harness/output/
.claude/worktrees/

# Screenshot captures from the screenshot-server Vite plugin
# (POST /__screenshot). Use `git add -f` to keep specific captures.
contrib/screenshots/*
!contrib/screenshots/.gitkeep

# DOF sweep output is large (~300 MB jsonl) and regenerated on demand by
# `npm run dof:sweep`.
contrib/debug/dof-sweep/

# Mutation testing outputs
reports/
.stryker-tmp/

# Per-developer state for scripts/test-mutation-if-changed.sh
.stryker-last-run

# Starlight docs site build artifacts
docs-site/node_modules
docs-site/dist
docs-site/.astro

# Per-developer build-goal annotation surfaced via the build-info Vite plugin
# (vite.config.ts). Free-form one-liner describing what the current dev
# server is for; read at server-start and exposed via `virtual:build-info`
# / GET /__build-info. Per-developer scratch — don't commit.
.build-goal
