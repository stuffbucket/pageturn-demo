---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active?: string;
}

const { title, description, active } = Astro.props;
const pages = [
  { href: '/pageturn-demo/', label: 'Overview' },
  { href: '/pageturn-demo/equations/', label: 'Equations' },
  { href: '/pageturn-demo/architecture/', label: 'Architecture' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Typography */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    {/* KaTeX stylesheet */}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
      integrity="sha384-zh0CIslj3dQfAA6Gx41c4amk+yp3tyKsrcMXjVRQiOl9UffDi65lGagQn3dkWT28"
      crossorigin="anonymous"
    />
  </head>

  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/pageturn-demo/" class="site-title">Page Turn</a>
        <nav>
          {pages.map(({ href, label }) => (
            <a href={href} class={active === label ? 'active' : ''}>
              {label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="content">
      <slot />
    </main>

    <footer class="site-footer">
      Page Turn Demo — Three.js · TypeScript · Vite
    </footer>
  </body>
</html>
